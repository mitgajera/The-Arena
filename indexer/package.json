{
  "name": "arena-indexer",
  "version": "0.1.0",
  "description": "Off-chain indexer and scorer for The Arena trading competition module",
  "main": "dist/index.js",
  "scripts": {
    "start": "ts-node src/index.ts",
    "build": "tsc",
    "test": "jest --runInBand",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.95.4",
    "drizzle-orm": "^0.36.4",
    "p-limit": "^3.1.0",
    "pg": "^8.13.1",
    "toml": "^3.0.0",
    "dotenv": "^16.4.5",
    "bn.js": "^5.2.1"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.6",
    "drizzle-kit": "^0.28.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["<rootDir>/../tests/ras.test.ts", "<rootDir>/../tests/bracket.test.ts"],
    "moduleNameMapper": {
      "^../indexer/src/(.*)$": "<rootDir>/src/$1"
    },
    "globals": {
      "ts-jest": {
        "tsconfig": {
          "rootDir": "..",
          "paths": {}
        }
      }
    }
  }
}
